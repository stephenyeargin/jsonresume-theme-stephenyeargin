<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">

  <title>{{ resume.basics.name }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
  <style>
    {{ resume.meta.css }}
  </style>
  <script>
    {{ resume.meta.js }}
  </script>
</head>

<body>

  <div class="container">
    <div>
      <h1>{{ resume.basics.name }}{% if resume.basics.label %}<span class="text-muted fw-lighter fw-italic">, {{ resume.basics.label }}</span>{% endif %}</h1>

      <div class="d-flex">
        <div class="align-self-center flex-grow-1">
          <blockquote class="lead py-3 clear">
            {{ resume.basics.summary }}
          </blockquote>
        </div>
        {% if resume.basics.image.size > 0 %}
        <div class="ps-4 align-self-center">
          <img src="{{ resume.basics.image }}" alt="Photo" class="rounded-circle img-thumbnail img-fluid">
        </div>
        {% endif %}
      </div>

      <div class="row">
        <div class="col-8">

          {% render './templates/work.liquid' with resume as resume %}

          {% render './templates/volunteer.liquid' with resume as resume %}

          {% render './templates/projects.liquid' with resume as resume %}

          {% render './templates/publications.liquid' with resume as resume %}

          {% render './templates/awards.liquid' with resume as resume %}

        </div>

        <div class="col-4">
          {% render './templates/basics.liquid' with resume as resume %}

          {% render './templates/education.liquid' with resume as resume %}

          {% render './templates/skills.liquid' with resume as resume %}

          {% render './templates/certifications.liquid' with resume as resume %}

          {% render './templates/interests.liquid' with resume as resume %}

          {% render './templates/references.liquid' with resume as resume %}
        </div>
      </div>
    </div>
  </div>
</body>
</html>
