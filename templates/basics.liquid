<section>
  <h2 id="connect"><i class="fa fa-handshake fa-fw"></i> Connect</h2>

  <dl class="row">
    <dt class="col-1 text-center">
      <i class="fa fa-location-pin fa-fw"></i>
      <span class="sr-only">Location</span>
    </dt>
    {% assign basics = resume.basics %}
    <dd class="col-11">
      {% if basics.location.address %}{{ basics.location.address }}<br>{% endif %}
      {{ basics.location.city }}, {{ basics.location.postalCode }} {{ basics.location.countryCode }}
    </dd>
    {% if basics.phone %}
    <dt class="col-1 text-center">
      <i class="fa fa-mobile fa-fw"></i>
      <span class="sr-only">Phone</span>
    </dt>
    <dd class="col-11">{{ basics.phone }}</dd>
    {% endif %}
    <dt class="col-1 text-center">
      <i class="fa fa-envelope fa-fw"></i>
      <span class="sr-only">Email</span>
    </dt>
    <dd class="col-11"><a href="mailto:{{ basics.email }}">{{ basics.email }}</a></dd>
    {% if resume.languages.size > 0 %}
    {% for language in resume.languages %}
    <dt class="col-1 text-center">
      <i class="fa fa-language fa-fw"></i>
      <span class="sr-only">Language</span>
    </dt>
    <dd class="col-11 text-truncate">
      {{ language.language }}{% if language.fluency %} ({{ language.fluency }}){% endif %}
    </dd>
    {% endfor %}
    {% endif %}
    {% for profile in basics.profiles %}
    {% assign network = profile.network | downcase %}
    <dt class="col-1 text-center">
      {% if network == "github" %}
      <i class="fab fa-github fa-fw"></i>
      {% elsif network == "linkedin" %}
      <i class="fab fa-linkedin fa-fw"></i>
      {% elsif network == "twitter" %}
      <i class="fab fa-twitter fa-fw"></i>
      {% else %}
      <i class="fa fa-globe fa-fw"></i>
      {% endif %}
      <span class="sr-only">{{ profile.network }}</span>
    </dt>
    <dd class="col-11 text-truncate"><a href="{{ profile.url }}" rel="me">{{ profile.url }}</a></dd>
    {% endfor %}
  </dl>
</section>
